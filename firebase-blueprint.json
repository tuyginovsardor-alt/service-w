{
  "entities": {
    "User": {
      "title": "User",
      "description": "Basic user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["uid", "displayName"]
    },
    "Resume": {
      "title": "Resume",
      "description": "Team member professional profile / resume",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "skills": { "type": "array" },
        "experience": { "type": "string" },
        "links": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "role", "bio"]
    },
    "Project": {
      "title": "Project",
      "description": "A project within the Wentric ecosystem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "logoUrl": { "type": "string" },
        "color": { "type": "string" },
        "tags": { "type": "array" },
        "status": { "type": "string" },
        "url": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "description"]
    },
    "Vision": {
      "title": "Vision",
      "description": "Company vision and values",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "values": { "type": "array" }
      }
    },
    "SupportSession": {
      "title": "Support Session",
      "description": "A chat session between a user and support/AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A message in a support chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" },
        "isAI": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/team/{memberId}": {
      "schema": "Resume",
      "description": "Publicly visible team portfolios"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Ecosystem projects"
    },
    "/vision/current": {
      "schema": "Vision",
      "description": "Company vision content"
    },
    "/support_chats/{chatId}": {
      "schema": "SupportSession",
      "description": "Active and past support sessions"
    },
    "/support_chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a support chat"
    }
  }
}
